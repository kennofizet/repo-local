{
    "name": "kennofizet/repo-local-backend",
    "description": "Local workspace git browser API (GitHub-style file tree, history, and diffs).",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "authors": [
        {
            "name": "KennoFizet",
            "email": "kennofizetreal@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "symfony/process": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Kennofizet\\RepoLocal\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kennofizet\\RepoLocal\\RepoLocalServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
